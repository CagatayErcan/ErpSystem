<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ERP Sistemi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/lotus.png" alt="Logo" height="30" class="me-2" />
                ERP Sistemi
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <!-- Ana Menü Dropdown'lar -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Ticari</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Cari/Index">Cari Yönetimi</a></li>
                            <li><a class="dropdown-item" href="/Stok">Stok Yönetimi</a></li>
                            <li><a class="dropdown-item disabled" href="#">Satın Alma Talepleri</a></li>
                            <li><a class="dropdown-item disabled" href="#">Teklif Yönetimi</a></li>
                            <li><a class="dropdown-item disabled" href="#">Satın Alma Siparişleri</a></li>
                            <li><a class="dropdown-item disabled" href="#">Fatura Yönetimi</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Üretim</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Urun">Ürün Kartları</a></li>
                            <li><a class="dropdown-item" href="/Bom">Malzeme Reçeteleri (BOM)</a></li>
                            <li><a class="dropdown-item" href="/IsMerkezi">İş Merkezleri</a></li>
                            <li><a class="dropdown-item disabled" href="#">İş Emirleri</a></li>
                            <li><a class="dropdown-item disabled" href="#">Üretim Faaliyet Formları</a></li>
                            <li><a class="dropdown-item" href="/MRP">MRP</a></li>  <!-- YENİ SATIR -->
                            <li><a class="dropdown-item disabled" href="#">Üretim Planlama</a></li>
                            <li><a class="dropdown-item disabled" href="#">Ürün Maliyetlendirme</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Lojistik</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item disabled" href="#">Hammadde Depo</a></li>
                            <li><a class="dropdown-item disabled" href="#">Teknik Depo</a></li>
                            <li><a class="dropdown-item disabled" href="#">Maça Stok</a></li>
                            <li><a class="dropdown-item disabled" href="#">Kalıp Stok</a></li>
                            <li><a class="dropdown-item disabled" href="#">Mamul Depo</a></li>
                            <li><a class="dropdown-item disabled" href="#">Paketleme</a></li>
                            <li><a class="dropdown-item disabled" href="#">Paket Listesi</a></li>
                            <li><a class="dropdown-item disabled" href="#">e-İrsaliye</a></li>
                            <li><a class="dropdown-item disabled" href="#">e-Fatura</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Yönetim</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/SatisSiparis">Satış Siparişleri</a></li>
                            <li><a class="dropdown-item disabled" href="#">Satış Planlama Onayları</a></li>
                            <li><a class="dropdown-item disabled" href="#">Üretim Planlama Takip</a></li>
                            <li><a class="dropdown-item disabled" href="#">Ürün Maliyet Analizi</a></li>
                        </ul>
                    </li>
                </ul>
                <!-- Sağ Taraf - Kullanıcı Bilgisi -->
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item">
                        <span class="nav-link text-warning" id="userName"></span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-danger btn-sm text-white" href="/Auth/Logout">Çıkış</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Kullanıcı adını localStorage'dan göster
        const userName = localStorage.getItem('username');
        if (userName) {
            document.getElementById('userName').innerText = userName;
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>