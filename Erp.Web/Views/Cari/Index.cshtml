@model IEnumerable<Erp.Data.Entities.Cari>

@{
    ViewData["Title"] = "Cari Yönetimi";
}

<style>
    #cariTable {
        width: 100% !important;
        border-collapse: collapse !important;
        table-layout: fixed !important;
    }

        #cariTable thead th {
            font-size: 13px;
            font-weight: bold;
            text-align: center;
            background-color: #f2f2f2;
            border: 1px solid #ddd !important;
            padding: 8px 6px !important;
            word-wrap: break-word !important;
            white-space: normal !important;
            overflow-wrap: break-word !important;
        }

        #cariTable tbody td {
            font-size: 12px;
            border: 1px solid #ddd !important;
            padding: 6px !important;
            vertical-align: middle;
            background-color: #fff;
            word-wrap: break-word !important;
            white-space: normal !important;
            overflow-wrap: break-word !important;
        }

        #cariTable tbody tr:hover td {
            background-color: #f5f5f5;
        }

        /* Sütun genişlikleri */
        #cariTable th:nth-child(1) {
            width: 80px;
        }

        #cariTable th:nth-child(2) {
            width: 150px;
        }

        #cariTable th:nth-child(3) {
            width: 80px;
        }

        #cariTable th:nth-child(4) {
            width: 80px;
        }

        #cariTable th:nth-child(5) {
            width: 70px;
        }

        #cariTable th:nth-child(6) {
            width: 100px;
        }

        #cariTable th:nth-child(7) {
            width: 90px;
        }

        #cariTable th:nth-child(8) {
            width: 100px;
        }

        #cariTable th:nth-child(9) {
            width: 100px;
        }

        #cariTable th:nth-child(10) {
            width: 100px;
        }

        #cariTable th:nth-child(11) {
            width: 100px;
        }

        #cariTable th:nth-child(12) {
            width: 90px;
        }

        #cariTable th:nth-child(13) {
            width: 120px;
        }

        #cariTable th:nth-child(14) {
            width: 100px;
        }

        #cariTable th:nth-child(15) {
            width: 60px;
        }

        #cariTable th:nth-child(16) {
            width: 70px;
        }

        #cariTable th:nth-child(17) {
            width: 70px;
        }

        #cariTable th:nth-child(18) {
            width: 80px;
        }

        #cariTable th:nth-child(19) {
            width: 150px;
        }

        #cariTable th:nth-child(20) {
            width: 100px;
        }

        #cariTable th:nth-child(21) {
            width: 80px;
        }

        #cariTable th:nth-child(22) {
            width: 80px;
        }

        #cariTable th:nth-child(23) {
            width: 70px;
        }

        #cariTable th:nth-child(24) {
            width: 80px;
        }

        #cariTable th:nth-child(25) {
            width: 90px;
        }

        #cariTable th:nth-child(26) {
            width: 90px;
        }

        #cariTable th:nth-child(27) {
            width: 130px;
        }

    .filter-row th {
        padding: 4px !important;
        background-color: #fafafa;
        border: 1px solid #ddd !important;
    }

    .filter-row input, .filter-row select {
        width: 100%;
        font-size: 11px;
        padding: 4px 6px;
        border: 1px solid #ccc;
        border-radius: 3px;
        box-sizing: border-box;
    }

    .btn-custom {
        display: inline-block;
        padding: 8px 16px;
        margin: 0 4px;
        font-size: 13px;
        font-weight: bold;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        color: white;
        text-decoration: none;
    }

    .btn-excel-custom {
        background-color: #1e7e34;
    }

    .btn-pdf-custom {
        background-color: #bd2130;
    }

    .btn-print-custom {
        background-color: #545b62;
    }

    .toolbar {
        margin-bottom: 15px;
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
    }

    .filter-badge {
        background-color: #007bff;
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: bold;
    }
</style>

<h1>Cari Kartları</h1>

<div class="toolbar">
    <a asp-action="Create" class="btn btn-primary btn-sm">Yeni Cari Ekle</a>
    <button id="clearAllFilters" class="btn btn-secondary btn-sm">Tüm Filtreleri Temizle</button>
    <span id="filterCount" class="filter-badge">0 filtre aktif</span>
</div>

<div style="overflow-x: auto; width: 100%;">
    <table id="cariTable" class="table table-bordered" style="width: 100%;">
        <thead>
            <tr>
                <th>Cari Kodu</th>
                <th>Cari Ünvanı</th>
                <th>Cari Kısa Ad</th>
                <th>Cari Tipi</th>
                <th>Durumu</th>
                <th>Vergi Dairesi</th>
                <th>Vergi No</th>
                <th>TCKN</th>
                <th>Mersis No</th>
                <th>Ticaret Sicil No</th>
                <th>Yetkili Kişi</th>
                <th>Telefon</th>
                <th>E-Posta</th>
                <th>Web Sitesi</th>
                <th>Ülke</th>
                <th>İl</th>
                <th>İlçe</th>
                <th>Posta Kodu</th>
                <th>Adres</th>
                <th>Satış Temsilcisi</th>
                <th>Bölge</th>
                <th>Sektör</th>
                <th>Döviz Türü</th>
                <th>Risk Limiti</th>
                <th>Oluşturma Tarihi</th>
                <th>Güncelleme Tarihi</th>
                <th>İşlemler</th>
            </tr>
            <tr class="filter-row">
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="0" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="1" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="2" /></th>
                <th><select class="column-filter" data-column="3"><option value="">Tümü</option><option>Müşteri</option><option>Tedarikçi</option><option>Her İkisi</option></select></th>
                <th><select class="column-filter" data-column="4"><option value="">Tümü</option><option>Aktif</option><option>Pasif</option></select></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="5" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="6" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="7" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="8" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="9" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="10" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="11" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="12" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="13" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="14" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="15" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="16" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="17" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="18" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="19" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="20" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="21" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="22" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="23" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="24" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="25" /></th>
                <th><input type="text" class="column-filter" placeholder="Filtre..." data-column="26" /></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CariKodu</td>
                    <td>@item.CariUnvani</td>
                    <td>@item.CariKisaAd</td>
                    <td>@item.CariTipi</td>
                    <td>@item.Durumu</td>
                    <td>@item.VergiDairesi</td>
                    <td>@item.VergiNo</td>
                    <td>@item.TCKN</td>
                    <td>@item.MersisNo</td>
                    <td>@item.TicaretSicilNo</td>
                    <td>@item.YetkiliKisi</td>
                    <td>@item.Telefon</td>
                    <td>@item.EPosta</td>
                    <td>@item.WebSitesi</td>
                    <td>@item.Ulke</td>
                    <td>@item.Il</td>
                    <td>@item.Ilce</td>
                    <td>@item.PostaKodu</td>
                    <td>@item.Adres</td>
                    <td>@item.SatisTemsilcisi</td>
                    <td>@item.Bolge</td>
                    <td>@item.Sektor</td>
                    <td>@item.DovizTuru</td>
                    <td>@item.RiskLimiti.ToString("N2")</td>
                    <td>@item.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                    <td>@(item.GuncellemeTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                    <td><a asp-action="Edit" asp-route-id="@item.CariKodu" class="btn btn-sm btn-warning">Düzenle</a> <a asp-action="Details" asp-route-id="@item.CariKodu" class="btn btn-sm btn-info">Detay</a> <a asp-action="Delete" asp-route-id="@item.CariKodu" class="btn btn-sm btn-danger">Sil</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <!-- DataTable CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/fixedheader/3.4.0/css/fixedHeader.dataTables.min.css" />

    <!-- jQuery (DataTable için gerekli) -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

    <!-- DataTable JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <!-- DataTable Buttons JS -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <!-- DataTable FixedHeader JS -->
    <script src="https://cdn.datatables.net/fixedheader/3.4.0/js/dataTables.fixedHeader.min.js"></script>

    <!-- Excel ve PDF için gerekli kütüphaneler -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>

    <script>
        $(document).ready(function () {
            $('#cariTable').DataTable({
                scrollY: '60vh',
                scrollX: true,
                scrollCollapse: true,
                fixedHeader: { header: true },
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json'
                },
                dom: 'Bfrtip',
                buttons: [
                    {
                        extend: 'excel',
                        text: '<i class="fas fa-file-excel"></i> Excel',
                        className: 'btn btn-success btn-sm',
                        exportOptions: {
                            columns: ':visible',
                            orthogonal: 'export',
                            format: {
                                header: function (data, columnIdx) {
                                    // Sadece gerçek başlıkları al (filtre satırını atla)
                                    var header = $('#cariTable thead tr:first th').eq(columnIdx).text();
                                    return header.trim();
                                },
                                body: function (data, row, column, node) {
                                    // Badge içindeki metni temizle
                                    if (data.includes('<span class="badge')) {
                                        var temp = document.createElement('div');
                                        temp.innerHTML = data;
                                        return temp.textContent || temp.innerText || '';
                                    }
                                    // Select içindeki seçili değeri al
                                    if (data.includes('<select')) {
                                        var temp = document.createElement('div');
                                        temp.innerHTML = data;
                                        var select = temp.querySelector('select');
                                        return select ? select.value : data;
                                    }
                                    // İşlemler sütunundaki linkleri temizle
                                    if (data.includes('<a') && data.includes('href=')) {
                                        var temp = document.createElement('div');
                                        temp.innerHTML = data;
                                        var links = temp.querySelectorAll('a');
                                        links.forEach(function (link) {
                                            var text = link.textContent || link.innerText || '';
                                            link.replaceWith(text);
                                        });
                                        return temp.textContent || temp.innerText || data;
                                    }
                                    return data;
                                }
                            }
                        }
                    },
                    {
                        extend: 'pdf',
                        text: '<i class="fas fa-file-pdf"></i> PDF',
                        className: 'btn btn-danger btn-sm',
                        exportOptions: {
                            columns: ':visible',
                            orthogonal: 'export',
                            format: {
                                header: function (data, columnIdx) {
                                    var header = $('#cariTable thead tr:first th').eq(columnIdx).text();
                                    return header.trim();
                                },
                                body: function (data, row, column, node) {
                                    if (data.includes('<span class="badge')) {
                                        var temp = document.createElement('div');
                                        temp.innerHTML = data;
                                        return temp.textContent || temp.innerText || '';
                                    }
                                    if (data.includes('<select')) {
                                        var temp = document.createElement('div');
                                        temp.innerHTML = data;
                                        var select = temp.querySelector('select');
                                        return select ? select.value : data;
                                    }
                                    if (data.includes('<a') && data.includes('href=')) {
                                        var temp = document.createElement('div');
                                        temp.innerHTML = data;
                                        var links = temp.querySelectorAll('a');
                                        links.forEach(function (link) {
                                            var text = link.textContent || link.innerText || '';
                                            link.replaceWith(text);
                                        });
                                        return temp.textContent || temp.innerText || data;
                                    }
                                    return data;
                                }
                            }
                        }
                    },
                    {
                        extend: 'print',
                        text: '<i class="fas fa-print"></i> Yazdır',
                        className: 'btn btn-secondary btn-sm'
                    }
                ],
                pageLength: 25,
                order: [[0, 'asc']]
            });
        });
    </script>
}