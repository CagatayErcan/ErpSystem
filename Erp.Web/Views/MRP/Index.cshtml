@{
    ViewData["Title"] = "MRP - Malzeme İhtiyaç Planlaması";
}

<style>
    .mrp-card {
        transition: transform 0.2s;
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

        .mrp-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        }

        .mrp-card .card-icon {
            font-size: 3rem;
            margin-bottom: 10px;
        }

        .mrp-card .card-title {
            font-weight: 600;
        }
</style>

<h1 class="mb-4">
    <i class="fas fa-industry text-primary"></i>
    MRP - Malzeme İhtiyaç Planlaması
</h1>

<div class="row mt-4">
    <!-- Alaşım Bazında Hammadde Oranları -->
    <div class="col-md-3">
        <div class="card mrp-card text-white bg-primary">
            <div class="card-body text-center">
                <div class="card-icon">
                    <i class="fas fa-flask"></i>
                </div>
                <h5 class="card-title">Alaşım Bazında Hammadde Oranları</h5>
                <p class="card-text small">Alaşım sınıflarına göre hammadde oranları</p>
                <a href="/MRP/AlasimOranlari" class="btn btn-light btn-sm">
                    <i class="fas fa-edit"></i> Yönet
                </a>
            </div>
        </div>
    </div>

    <!-- Kalıp Sarf Oranları -->
    <div class="col-md-3">
        <div class="card mrp-card text-white bg-success">
            <div class="card-body text-center">
                <div class="card-icon">
                    <i class="fas fa-cube"></i>
                </div>
                <h5 class="card-title">Kalıp Sarf Oranları</h5>
                <p class="card-text small">Kalıp cinsine göre sarf malzeme oranları</p>
                <a href="/MRP/KalipSarfOranlari" class="btn btn-light btn-sm">
                    <i class="fas fa-edit"></i> Yönet
                </a>
            </div>
        </div>
    </div>

    <!-- Maça Sarf Oranları -->
    <div class="col-md-3">
        <div class="card mrp-card text-white bg-warning">
            <div class="card-body text-center">
                <div class="card-icon">
                    <i class="fas fa-drafting-compass"></i>
                </div>
                <h5 class="card-title">Maça Sarf Oranları</h5>
                <p class="card-text small">Maça cinsine göre sarf malzeme oranları</p>
                <a href="/MRP/MacaSarfOranlari" class="btn btn-dark btn-sm">
                    <i class="fas fa-edit"></i> Yönet
                </a>
            </div>
        </div>
    </div>

    <!-- Enerji Standartları -->
    <div class="col-md-3">
        <div class="card mrp-card text-white bg-info">
            <div class="card-body text-center">
                <div class="card-icon">
                    <i class="fas fa-bolt"></i>
                </div>
                <h5 class="card-title">Enerji Standartları</h5>
                <p class="card-text small">Proses bazında enerji tüketim standartları</p>
                <a href="/MRP/EnerjiStandartlari" class="btn btn-light btn-sm">
                    <i class="fas fa-edit"></i> Yönet
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Alt Bilgi -->
<div class="row mt-5">
    <div class="col-12 text-center text-muted">
        <small>
            <i class="fas fa-info-circle"></i>
            MRP modülü, üretim süreçlerinde kullanılan standart reçete ve oranları yönetir.
        </small>
    </div>
</div>