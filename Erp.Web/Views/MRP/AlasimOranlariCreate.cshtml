@model Erp.Data.Entities.AlasimHammaddeOranlari

@{
    ViewData["Title"] = "Yeni Alaşım Oranı Ekle";
}

<style>
    .row-ekle {
        background-color: #f8f9fa;
        padding: 10px;
        border-radius: 5px;
        margin-top: 10px;
    }

    .satir-sil {
        cursor: pointer;
        color: red;
    }

        .satir-sil:hover {
            color: darkred;
        }
</style>

<h1>
    <i class="fas fa-plus-circle text-success"></i>
    Yeni Alaşım Oranı Ekle
</h1>
<hr />

<div class="row">
    <div class="col-md-12">
        <form asp-action="AlasimOranlariCreate" method="post" id="alasimForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Alaşım Sınıfı Seçimi -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="AlasimSinifi" class="control-label fw-bold"></label>
                        <select asp-for="AlasimSinifi" class="form-control" id="AlasimSinifi">
                            <option value="">Seçiniz</option>
                            <option value="GG20">GG20</option>
                            <option value="GG25">GG25</option>
                            <option value="GG30">GG30</option>
                            <option value="GGG40">GGG40</option>
                            <option value="GGG50">GGG50</option>
                            <option value="GGG60">GGG60</option>
                        </select>
                        <span asp-validation-for="AlasimSinifi" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-8 d-flex align-items-end">
                    <button type="button" class="btn btn-success" onclick="satirEkle()">
                        <i class="fas fa-plus"></i> Satır Ekle
                    </button>
                    <button type="button" class="btn btn-secondary ms-2" onclick="ornekVeriDoldur()">
                        <i class="fas fa-database"></i> Örnek Veri Doldur
                    </button>
                </div>
            </div>

            <!-- Oranlar Tablosu -->
            <div class="table-responsive">
                <table class="table table-bordered" id="oranlarTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:20%;">Stok Tipi</th>
                            <th style="width:30%;">Hammadde Adı</th>
                            <th style="width:20%;">Hammadde Kodu</th>
                            <th style="width:20%;">Oran (%)</th>
                            <th style="width:10%;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="oranlarTbody">
                        <!-- JavaScript ile satırlar eklenecek -->
                    </tbody>
                </table>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Tümünü Kaydet" class="btn btn-primary btn-lg" />
                <a asp-action="AlasimOranlari" class="btn btn-secondary btn-lg">Listeye Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ==========================================
        // SATIR EKLE
        // ==========================================
        function satirEkle() {
            var tbody = document.getElementById('oranlarTbody');
            var row = tbody.insertRow();
            var index = tbody.rows.length - 1; // Satır sayısına göre indeks

            row.innerHTML = `
                        <td>
                            <select class="form-control form-control-sm stok-tipi" name="StokTipi[${index}]">
                                <option value="">Seçiniz</option>
                                @if (ViewBag.StokTipleri != null)
                                {
                                    foreach (var tip in ViewBag.StokTipleri)
                                        {
                                            <option value="@tip">@tip</option>
                                        }
                                }
                            </select>
                        </td>
                <td>
                    <select class="form-control form-control-sm stok-adi" data-row="alasim" name="HammaddeAdi[${index}]">
                        <option value="">Önce Stok Tipi Seçin</option>
                    </select>
                </td>
                <td>
                    <input type="text" class="form-control form-control-sm stok-kodu" name="HammaddeKodu[${index}]" readonly />
                </td>
                <td>
                    <input type="number" step="any" name="Oran[${index}]" class="form-control form-control-sm" placeholder="Örn: 95.00" required />
                </td>
                <td class="text-center">
                    <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                </td>
            `;
        }

        // ==========================================
        // SATIR SİL
        // ==========================================
        function satirSil(element) {
            var row = element.closest('tr');
            row.remove();
        }

        // ==========================================
        // STOK TİPİNE GÖRE STOK ADLARINI GETİR
        // ==========================================
        $(document).on('change', '.stok-tipi', function () {
            var row = $(this).closest('tr');
            var stokTipi = $(this).val();
            var stokAdiSelect = row.find('.stok-adi');
            var stokKoduInput = row.find('.stok-kodu');

            stokAdiSelect.empty();
            stokAdiSelect.append('<option value="">Seçiniz</option>');

            if (stokTipi) {
                $.ajax({
                    url: '/MRP/GetStoklarByTip',
                    type: 'GET',
                    data: { stokTipi: stokTipi },
                    success: function (data) {
                        $.each(data, function (index, item) {
                            stokAdiSelect.append('<option value="' + item.stokAdi + '" data-stokkodu="' + item.stokKodu + '">' + item.stokAdi + '</option>');
                        });
                    },
                    error: function () {
                        alert('Stoklar yüklenirken bir hata oluştu.');
                    }
                });
            }
        });

        // ==========================================
        // STOK ADI SEÇİLDİĞİNDE STOK KODUNU DOLDUR
        // ==========================================
        $(document).on('change', '.stok-adi', function () {
            var row = $(this).closest('tr');
            var selectedOption = $(this).find('option:selected');
            var stokKodu = selectedOption.data('stokkodu');
            row.find('.stok-kodu').val(stokKodu || '');
        });

        // ==========================================
        // ÖRNEK VERİ DOLDUR (GG20 için)
        // ==========================================
        // ==========================================
        // ÖRNEK VERİ DOLDUR (Son Kaydedilen Veri ile)
        // ==========================================
        function ornekVeriDoldur() {
            var tbody = document.getElementById('oranlarTbody');

            // Cinsi seç (Alaşım/Kalıp/Maça)
            var cinsSelect = document.getElementById('AlasimSinifi') ||
                document.getElementById('KalipCinsi') ||
                document.getElementById('MacaCinsi');

            var cins = cinsSelect ? cinsSelect.value : '';

            if (!cins) {
                alert('Lütfen önce bir cins seçiniz.');
                return;
            }

            // AJAX ile son kayıtları getir
            var url = '';
            if (document.getElementById('AlasimSinifi')) {
                url = '/MRP/GetSonAlasimOranlari';
            } else if (document.getElementById('KalipCinsi')) {
                url = '/MRP/GetSonKalipSarfOranlari';
            } else if (document.getElementById('MacaCinsi')) {
                url = '/MRP/GetSonMacaSarfOranlari';
            }

            $.ajax({
                url: url,
                type: 'GET',
                data: { alasimSinifi: cins, kalipCinsi: cins, macaCinsi: cins },
                success: function (data) {
                    if (data && data.length > 0) {
                        tbody.innerHTML = '';
                        data.forEach(function (item, index) {
                            var row = tbody.insertRow();
                            row.innerHTML = `
                                <td>
                                    <select class="form-control form-control-sm stok-tipi" name="StokTipi[${index}]">
                                        <option value="">Seçiniz</option>
                                        ${stokTipleri.map(tip => `<option value="${tip}" ${tip === item.stokTipi ? 'selected' : ''}>${tip}</option>`).join('')}
                                    </select>
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="${document.getElementById('AlasimSinifi') ? 'HammaddeAdi' : 'SarfAdi'}[${index}]" value="${item.hammaddeAdi || item.sarfAdi || ''}" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="${document.getElementById('AlasimSinifi') ? 'HammaddeKodu' : 'SarfKodu'}[${index}]" value="${item.hammaddeKodu || item.sarfKodu || ''}" />
                                </td>
                                ${document.getElementById('AlasimSinifi') ? '' : `
                                <td>
                                    <select class="form-control form-control-sm" name="Birim[${index}]">
                                        <option value="KG" ${item.birim === 'KG' ? 'selected' : ''}>KG</option>
                                        <option value="LT" ${item.birim === 'LT' ? 'selected' : ''}>LT</option>
                                        <option value="ADET" ${item.birim === 'ADET' ? 'selected' : ''}>ADET</option>
                                    </select>
                                </td>
                                `}
                                <td>
                                    <input type="number" step="any" name="${document.getElementById('AlasimSinifi') ? 'Oran' : 'Miktar'}[${index}]" class="form-control form-control-sm" value="${item.oran || item.miktar || 0}" />
                                </td>
                                <td class="text-center">
                                    <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                                </td>
                            `;
                        });
                    } else {
                        alert('Bu cins için kayıtlı veri bulunamadı.');
                    }
                },
                error: function () {
                    alert('Veriler yüklenirken bir hata oluştu.');
                }
            });
        }

        // ==========================================
        // FORM GÖNDERİLMEDEN ÖNCE VERİLERİ TOPLA
        // ==========================================
        document.getElementById('alasimForm').addEventListener('submit', function (e) {
            var alasimSinifi = document.getElementById('AlasimSinifi').value;
            if (!alasimSinifi) {
                alert('Lütfen bir alaşım sınıfı seçiniz.');
                e.preventDefault();
                return;
            }

            var rows = document.querySelectorAll('#oranlarTbody tr');
            if (rows.length === 0) {
                alert('Lütfen en az bir satır ekleyiniz.');
                e.preventDefault();
                return;
            }

            var valid = true;
            rows.forEach(function (row) {
                var inputs = row.querySelectorAll('input, select');
                inputs.forEach(function (input) {
                    if (!input.value.trim()) {
                        valid = false;
                        input.style.borderColor = 'red';
                    } else {
                        input.style.borderColor = '';
                    }
                });
            });

            if (!valid) {
                alert('Lütfen tüm alanları doldurunuz.');
                e.preventDefault();
            }
        });
    </script>
}