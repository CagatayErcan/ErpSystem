@model List<Erp.Data.Entities.AlasimHammaddeOranlari>

@{
    ViewData["Title"] = "Alaşım Oranlarını Düzenle";
    var alasimSinifi = ViewBag.AlasimSinifi as string ?? "";
}

<style>
    .satir-sil {
        cursor: pointer;
        color: red;
    }

        .satir-sil:hover {
            color: darkred;
        }
</style>

<h1>
    <i class="fas fa-edit text-warning"></i>
    Alaşım Oranlarını Düzenle - @alasimSinifi
</h1>
<hr />

<div class="row">
    <div class="col-md-12">
        <form asp-action="AlasimOranlariEdit" method="post" id="alasimForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="AlasimSinifi" value="@alasimSinifi" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="table-responsive">
                <table class="table table-bordered" id="oranlarTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:20%;">Stok Tipi</th>
                            <th style="width:30%;">Hammadde Adı</th>
                            <th style="width:20%;">Hammadde Kodu</th>
                            <th style="width:20%;">Oran (%)</th>
                            <th style="width:10%;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="oranlarTbody">
                        @if (Model != null && Model.Any())
                        {
                            int index = 0;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <select class="form-control form-control-sm" name="kayitlar[@index].StokTipi">
                                            <option value="">Seçiniz</option>
                                            @if (ViewBag.StokTipleri != null)
                                            {
                                                foreach (var tip in ViewBag.StokTipleri)
                                                {
                                                    if (item.StokTipi == tip)
                                                    {
                                                        <option value="@tip" selected>@tip</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@tip">@tip</option>
                                                    }
                                                }
                                            }
                                        </select>
                                        <input type="hidden" name="kayitlar[@index].Id" value="@item.Id" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" name="kayitlar[@index].HammaddeAdi" value="@item.HammaddeAdi" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" name="kayitlar[@index].HammaddeKodu" value="@item.HammaddeKodu" />
                                    </td>
                                    <td>
                                        <input type="number" step="any" name="kayitlar[@index].Oran" class="form-control form-control-sm" value="@item.Oran.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                    </td>
                                    <td class="text-center">
                                        <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <button type="button" class="btn btn-success" onclick="satirEkle()">
                    <i class="fas fa-plus"></i> Satır Ekle
                </button>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Tümünü Güncelle
                </button>
                <a asp-action="AlasimOranlari" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Listeye Dön
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function satirEkle() {
            var tbody = document.getElementById('oranlarTbody');
            var row = tbody.insertRow();
            var index = tbody.rows.length - 1;

            row.innerHTML = `
                        <td>
                                    <select class="form-control form-control-sm stok-tipi" name="StokTipi[${index}]">
                                    <option value="">Seçiniz</option>
                                        @if (ViewBag.StokTipleri != null)
                                        {
                                            foreach (var tip in ViewBag.StokTipleri)
                                            {
                                                <option value="@tip">@tip</option>
                                            }
                                        }
                                    </select>
                        </td>
                        <td>
                            <input type="text" class="form-control form-control-sm" name="kayitlar[${index}].HammaddeAdi" placeholder="Hammadde Adı" />
                        </td>
                        <td>
                            <input type="text" class="form-control form-control-sm" name="kayitlar[${index}].HammaddeKodu" placeholder="Kod" />
                        </td>
                        <td>
                            <input type="number" step="any" name="kayitlar[${index}].Oran" class="form-control form-control-sm" placeholder="Oran" />
                        </td>
                        <td class="text-center">
                            <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                        </td>
                    `;
        }

        function satirSil(element) {
            var row = element.closest('tr');
            row.remove();
        }
    </script>
}