@model List<Erp.Data.Entities.KalipSarfOranlari>

@{
    ViewData["Title"] = "Kalıp Sarf Oranlarını Düzenle";
    var kalipCinsi = ViewBag.KalipCinsi as string ?? "";
}

<style>
    .satir-sil { cursor: pointer; color: red; }
    .satir-sil:hover { color: darkred; }
</style>

<h1>
    <i class="fas fa-edit text-warning"></i>
    Kalıp Sarf Oranlarını Düzenle - @kalipCinsi
</h1>
<hr />

<div class="row">
    <div class="col-md-12">
        <form asp-action="KalipSarfOranlariEdit" method="post" id="kalipForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="KalipCinsi" value="@kalipCinsi" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="table-responsive">
                <table class="table table-bordered" id="oranlarTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:18%;">Stok Tipi</th>
                            <th style="width:27%;">Sarf Adı</th>
                            <th style="width:20%;">Sarf Kodu</th>
                            <th style="width:15%;">Birim</th>
                            <th style="width:20%;">Miktar (%)</th>
                            <th style="width:10%;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="oranlarTbody">
                        @if (Model != null && Model.Any())
{
    int index = 0;
    foreach (var item in Model)
    {
        <tr>
            <td>
                <select class="form-control form-control-sm stok-tipi" data-row="kalip" name="kayitlar[@index].StokTipi">
                    <option value="">Seçiniz</option>
                    @if (item.StokTipi == "Hammadde")
                    {
                        <option value="Hammadde" selected>Hammadde</option>
                        <option value="Sarf">Sarf</option>
                        <option value="Hizmet">Hizmet</option>
                        <option value="Demirbaş">Demirbaş</option>
                        <option value="Yarı Mamul">Yarı Mamul</option>
                    }
                    else if (item.StokTipi == "Sarf")
                    {
                        <option value="Hammadde">Hammadde</option>
                        <option value="Sarf" selected>Sarf</option>
                        <option value="Hizmet">Hizmet</option>
                        <option value="Demirbaş">Demirbaş</option>
                        <option value="Yarı Mamul">Yarı Mamul</option>
                    }
                    // ... diğer tipler
                    else
                    {
                        <option value="Hammadde">Hammadde</option>
                        <option value="Sarf">Sarf</option>
                        <option value="Hizmet">Hizmet</option>
                        <option value="Demirbaş">Demirbaş</option>
                        <option value="Yarı Mamul">Yarı Mamul</option>
                    }
                </select>
                <input type="hidden" name="kayitlar[@index].Id" value="@item.Id" />
            </td>
            <td>
                <select class="form-control form-control-sm stok-adi" data-row="kalip" name="kayitlar[@index].SarfAdi">
                    <option value="@item.SarfAdi">@item.SarfAdi</option>
                </select>
            </td>
            <td>
                <input type="text" class="form-control form-control-sm" name="kayitlar[@index].SarfKodu" value="@item.SarfKodu" />
            </td>
            <td>
                                        <select class="form-control form-control-sm" name="kayitlar[@index].Birim">
                                            @if (item.Birim == "KG")
                                            {
                                                <option value="KG" selected>KG</option>
                                                <option value="LT">LT</option>
                                                <option value="ADET">ADET</option>
                                            }
                                            else if (item.Birim == "LT")
                                            {
                                                <option value="KG">KG</option>
                                                <option value="LT" selected>LT</option>
                                                <option value="ADET">ADET</option>
                                            }
                                            else if (item.Birim == "ADET")
                                            {
                                                <option value="KG">KG</option>
                                                <option value="LT">LT</option>
                                                <option value="ADET" selected>ADET</option>
                                            }
                                            else
                                            {
                                                <option value="KG">KG</option>
                                                <option value="LT">LT</option>
                                                <option value="ADET">ADET</option>
                                            }
                                        </select>
            </td>
            <td>
                <input type="number" step="any" name="kayitlar[@index].Miktar" class="form-control form-control-sm" value="@item.Miktar" />
            </td>
            <td class="text-center">
                <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
            </td>
        </tr>
        index++;
    }
}
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <button type="button" class="btn btn-success" onclick="satirEkle()">
                    <i class="fas fa-plus"></i> Satır Ekle
                </button>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Tümünü Güncelle
                </button>
                <a asp-action="KalipSarfOranlari" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Listeye Dön
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function satirEkle() {
            var tbody = document.getElementById('oranlarTbody');
            var row = tbody.insertRow();
            var index = tbody.rows.length - 1;

            row.innerHTML = `
                <td>
                            <select class="form-control form-control-sm stok-tipi" name="StokTipi[${index}]">
                                <option value="">Seçiniz</option>
                                 @if (ViewBag.StokTipleri != null)
                                 {
                                    foreach (var tip in ViewBag.StokTipleri)
                                    {
                                        <option value="@tip">@tip</option>
                                    }
                                 }
                            </select>
                </td>
                <td>
                    <select class="form-control form-control-sm stok-adi" data-row="kalip" name="kayitlar[${index}].SarfAdi">
                        <option value="">Önce Stok Tipi Seçin</option>
                    </select>
                </td>
                <td>
                    <input type="text" class="form-control form-control-sm stok-kodu" name="kayitlar[${index}].SarfKodu" readonly />
                </td>
                <td>
                    <select class="form-control form-control-sm" name="kayitlar[${index}].Birim">
                        <option value="KG">KG</option>
                        <option value="LT">LT</option>
                        <option value="ADET">ADET</option>
                    </select>
                </td>
                <td>
                    <input type="number" step="any" name="kayitlar[${index}].Miktar" class="form-control form-control-sm" placeholder="Örn: 1.5" />
                </td>
                <td class="text-center">
                    <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                </td>
            `;
        }

        function satirSil(element) {
            var row = element.closest('tr');
            row.remove();
        }
        // ==========================================
        // STOK TİPİNE GÖRE STOK ADLARINI GETİR (EDIT SAYFASI İÇİN)
        // ==========================================
        $(document).on('change', '.stok-tipi', function () {
            var row = $(this).closest('tr');
            var stokTipi = $(this).val();
            var stokAdiSelect = row.find('.stok-adi');
            var stokKoduInput = row.find('.stok-kodu');

            stokAdiSelect.empty();
            stokAdiSelect.append('<option value="">Seçiniz</option>');

            if (stokTipi) {
                $.ajax({
                    url: '/MRP/GetStoklarByTip',
                    type: 'GET',
                    data: { stokTipi: stokTipi },
                    success: function (data) {
                        $.each(data, function (index, item) {
                            stokAdiSelect.append('<option value="' + item.stokAdi + '" data-stokkodu="' + item.stokKodu + '">' + item.stokAdi + '</option>');
                        });
                    },
                    error: function () {
                        alert('Stoklar yüklenirken bir hata oluştu.');
                    }
                });
            }
        });

        // ==========================================
        // STOK ADI SEÇİLDİĞİNDE STOK KODUNU DOLDUR
        // ==========================================
        $(document).on('change', '.stok-adi', function () {
            var row = $(this).closest('tr');
            var selectedOption = $(this).find('option:selected');
            var stokKodu = selectedOption.data('stokkodu');
            var stokKoduInput = row.find('input[name$=".SarfKodu"]');
            if (stokKoduInput.length === 0) {
                stokKoduInput = row.find('.stok-kodu');
            }
            stokKoduInput.val(stokKodu || '');
        });
    </script>
}