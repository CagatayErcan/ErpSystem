@model IEnumerable<Erp.Data.Entities.MacaSarfOranlari>

@{
    ViewData["Title"] = "Maça Sarf Oranları";
}

<style>
    .btn-sm {
        font-size: 10px;
        padding: 2px 6px;
    }
</style>

<h1>
    <i class="fas fa-drafting-compass text-warning"></i>
    Maça Sarf Oranları
</h1>

<p>
    <a asp-action="MacaSarfOranlariCreate" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Oran Ekle
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> MRP Ana Sayfa
    </a>
</p>

<div style="overflow-x: auto; width: 100%;">
    <table id="macaTable" class="table table-bordered table-striped" style="width: 100%;">
        <thead>
            <tr>
                <th>Maça Cinsi</th>
                <th>Stok Tipi</th>
                <th>Sarf Kodu</th>
                <th>Sarf Adı</th>
                <th>Birim</th>
                <th>Miktar (%)</th>
                <th>Oluşturma Tarihi</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MacaCinsi</td>
                        <td>@item.StokTipi</td>
                        <td>@item.SarfKodu</td>
                        <td>@item.SarfAdi</td>
                        <td>@item.Birim</td>
                        <td>@item.Miktar.ToString("N2") %</td>
                        <td>@item.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a asp-action="MacaSarfOranlariEdit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Düzenle">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="MacaSarfOranlariDelete" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger" title="Sil" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">Henüz kayıt bulunmuyor.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#macaTable').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json' },
                pageLength: 25,
                order: [[0, 'asc']]
            });
        });
    </script>
}