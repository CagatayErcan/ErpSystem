@model IEnumerable<Erp.Data.Entities.AlasimHammaddeOranlari>

@{
    ViewData["Title"] = "Alaşım Bazında Hammadde Oranları";
}

<style>
    .btn-sm {
        font-size: 10px;
        padding: 2px 6px;
    }
</style>

<h1>
    <i class="fas fa-flask text-primary"></i>
    Alaşım Bazında Hammadde Oranları
</h1>

<p>
    <a asp-action="AlasimOranlariCreate" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Oran Ekle
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> MRP Ana Sayfa
    </a>
</p>

<div style="overflow-x: auto; width: 100%;">
    <table id="alasimTable" class="table table-bordered table-striped" style="width: 100%;">
        <thead>
            <tr>
                <th>Alaşım Sınıfı</th>
                <th>Hammadde Kodu</th>
                <th>Hammadde Adı</th>
                <th>Oran (%)</th>
                <th>Oluşturma Tarihi</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AlasimSinifi</td>
                    <td>@item.HammaddeKodu</td>
                    <td>@item.HammaddeAdi</td>
                    <td>@item.Oran.ToString("N2")</td>
                    <td>@item.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a asp-action="AlasimOranlariEdit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Düzenle">
                            <i class="fas fa-edit"></i>
                        </a>
                        <form asp-action="AlasimOranlariDelete" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Sil" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#alasimTable').DataTable({
                scrollY: '60vh',
                scrollX: true,
                scrollCollapse: true,
                fixedHeader: { header: true },
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json' },
                pageLength: 25,
                order: [[0, 'asc']]
            });
        });
    </script>
}