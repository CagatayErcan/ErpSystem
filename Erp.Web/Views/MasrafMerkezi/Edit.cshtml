@model Erp.Data.Entities.MasrafMerkezi

@{
    ViewData["Title"] = "Masraf Merkezi Düzenle";
}

<h1>Masraf Merkezi Düzenle</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Kod" />
            <input type="hidden" asp-for="OlusturmaTarihi" />

            <!-- Kod - Readonly -->
            <div class="form-group mb-3">
                <label asp-for="Kod" class="control-label"></label>
                <input asp-for="Kod" class="form-control" readonly style="background-color: #e9ecef;" />
            </div>

            <!-- Ad - Otomatik tamamlama yok -->
            <div class="form-group mb-3">
                <label asp-for="Ad" class="control-label"></label>
                <input asp-for="Ad" class="form-control" autocomplete="off" />
                <span asp-validation-for="Ad" class="text-danger"></span>
            </div>

            <!-- Ana Grup - Dropdown -->
            <div class="form-group mb-3">
                <label asp-for="AnaGrup" class="control-label"></label>
                <select asp-for="AnaGrup" class="form-control">
                    <option value="">Seçiniz</option>
                    @if (ViewBag.AnaGruplari != null)
                    {
                        foreach (var item in ViewBag.AnaGruplari)
                        {
                            if (Model.AnaGrup == item)
                            {
                                <option value="@item" selected>@item</option>
                            }
                            else
                            {
                                <option value="@item">@item</option>
                            }
                        }
                    }
                </select>
            </div>

            <!-- Durum - Düzeltilmiş -->
            <div class="form-group mb-3">
                <label asp-for="Durum" class="control-label"></label>
                <select asp-for="Durum" class="form-control">
                    @if (Model.Durum == "Aktif")
                    {
                        <option value="Aktif" selected>Aktif</option>
                        <option value="Pasif">Pasif</option>
                    }
                    else
                    {
                        <option value="Aktif">Aktif</option>
                        <option value="Pasif" selected>Pasif</option>
                    }
                </select>
                <span asp-validation-for="Durum" class="text-danger"></span>
            </div>

            <!-- Açıklama -->
            <div class="form-group mb-3">
                <label asp-for="Aciklama" class="control-label"></label>
                <textarea asp-for="Aciklama" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Güncelle" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}