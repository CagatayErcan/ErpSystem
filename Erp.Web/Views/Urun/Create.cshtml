@model Erp.Data.Entities.Urun
@if (Model == null)
{
    <div class="alert alert-warning">
        <strong>Uyarı!</strong> Yeni ürün oluşturuyorsunuz. Reçeteler henüz tanımlanmamış.
    </div>
}

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<h1>Yeni Ürün Ekle</h1>
<hr />

<form asp-action="Create" method="post" id="urunForm">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <!-- ================================================ -->
    <!-- 1. ÜRÜN KARTI BİLGİLERİ -->
    <!-- ================================================ -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Ürün Kartı</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="UrunKodu" class="control-label"></label>
                        <input asp-for="UrunKodu" class="form-control" />
                        <span asp-validation-for="UrunKodu" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="UrunAdi" class="control-label"></label>
                        <input asp-for="UrunAdi" class="form-control" />
                        <span asp-validation-for="UrunAdi" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label class="control-label">Müşteri</label>
                        <select class="form-control" id="MusteriKisaAd" name="MusteriKisaAd">
                            <option value="">Seçiniz</option>
                            @if (ViewBag.MusteriListesi != null)
                            {
                                foreach (var cari in ViewBag.MusteriListesi)
                                {
                                    if (Model?.MusteriKisaAd == cari.CariKisaAd)
                                    {
                                        <option value="@cari.CariKisaAd" selected>@cari.CariKisaAd</option>
                                    }
                                    else
                                    {
                                        <option value="@cari.CariKisaAd">@cari.CariKisaAd</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Alasim" class="control-label"></label>
                        <select asp-for="Alasim" class="form-control" id="Alasim">
                            <option value="">Seçiniz</option>
                            <option value="PİK">PİK</option>
                            <option value="SFERO">SFERO</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AlasimNormu" class="control-label"></label>
                        <select asp-for="AlasimNormu" class="form-control" id="AlasimNormu">
                            <option value="">Önce Alaşım Seçiniz</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="UrunAgirligi" class="control-label"></label>
                        <input asp-for="UrunAgirligi" class="form-control" />
                        <span asp-validation-for="UrunAgirligi" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="UrunKalipNo" class="control-label"></label>
                        <input asp-for="UrunKalipNo" class="form-control" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="KalipCinsi" class="control-label"></label>
                        <select asp-for="KalipCinsi" class="form-control">
                            <option value="">Seçiniz</option>
                            <option value="REÇİNELİ">REÇİNELİ</option>
                            <option value="BENTONİTLİ">BENTONİTLİ</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="KalipAgirligi" class="control-label"></label>
                        <input asp-for="KalipAgirligi" class="form-control" type="number" step="any" />
                        <span asp-validation-for="KalipAgirligi" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="UrunParcaAdeti" class="control-label"></label>
                        <input asp-for="UrunParcaAdeti" class="form-control" type="number" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="KalipCevrimSuresi" class="control-label"></label>
                        <input asp-for="KalipCevrimSuresi" class="form-control" type="number" placeholder="dk" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="BesleyiciStokKodu" class="control-label"></label>
                            <select asp-for="BesleyiciStokKodu" class="form-control" id="BesleyiciStokKodu" onchange="showBesleyiciDescription(this)">
                                <option value="">Seçiniz</option>
                                @if (ViewBag.BesleyiciListesi != null)
                                {
                                    foreach (var item in ViewBag.BesleyiciListesi)
                                    {
                                        if (Model?.BesleyiciStokKodu == item.StokKodu)
                                        {
                                            <option value="@item.StokKodu" data-aciklama="@item.Aciklama" selected>@item.StokAdi (@item.StokKodu)</option>
                                        }
                                        else
                                        {
                                            <option value="@item.StokKodu" data-aciklama="@item.Aciklama">@item.StokAdi (@item.StokKodu)</option>
                                        }
                                    }
                                }
                            </select>
                            <div id="besleyiciAciklama" class="text-muted small mt-1"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="BesleyiciAdeti" class="control-label"></label>
                            <input asp-for="BesleyiciAdeti" class="form-control" type="number" />
                            <span asp-validation-for="BesleyiciAdeti" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="FireOrani" class="control-label"></label>
                        <input asp-for="FireOrani" class="form-control" type="number" step="any" />
                        <span asp-validation-for="FireOrani" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Aciklama" class="control-label"></label>
                <textarea asp-for="Aciklama" class="form-control" rows="2"></textarea>
            </div>
        </div>
    </div>

    <!-- ================================================ -->
    <!-- 2. ERGİTME REÇETESİ -->
    <!-- ================================================ -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Ergitme Reçetesi - Hammadde</h5>
            <button type="button" class="btn btn-warning btn-sm" onclick="otomatikOlustur()">
                <i class="fas fa-magic"></i> Oluştur
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="ergitmeTable">
                    <thead>
                        <tr>
                            <th>Stok Tipi</th>
                            <th>Stok Adı</th>
                            <th>Stok Kodu</th>
                            <th>Miktar (kg)</th>
                            <th>Birim</th>
                            <th style="width:50px;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="ergitmeTbody">
                        <!-- JavaScript ile otomatik doldurulacak -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- ================================================ -->
    <!-- KALIP REÇETESİ -->
    <!-- ================================================ -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Kalıp Reçetesi</h5>
            <button type="button" class="btn btn-light btn-sm" onclick="kalipOtomatikOlustur()">
                <i class="fas fa-magic"></i> Oluştur
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="kalipTable">
                    <thead>
                        <tr>
                            <th>Stok Tipi</th>
                            <th>Stok Adı</th>
                            <th>Stok Kodu</th>
                            <th>Miktar</th>
                            <th>Birim</th>
                            <th style="width:50px;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="kalipTbody">
                        @if (Model != null && Model.KalipReceteleri != null && Model.KalipReceteleri.Any())
                        {
                            int index = 0;
                            foreach (var item in Model.KalipReceteleri)
                            {
                                <tr>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" name="KalipReceteleri[@index].StokTipi" value="@item.StokTipi" readonly style="background-color: #e9ecef;" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" name="KalipReceteleri[@index].StokAdi" value="@item.StokAdi" readonly style="background-color: #e9ecef;" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" name="KalipReceteleri[@index].StokKodu" value="@item.StokKodu" readonly style="background-color: #e9ecef;" />
                                    </td>
                                    <td>
                                        <input type="number" step="any" name="KalipReceteleri[@index].Miktar" class="form-control form-control-sm" value="@item.Miktar.ToString(System.Globalization.CultureInfo.InvariantCulture)" readonly style="background-color: #e9ecef;" />
                                    </td>
                                    <td>
                                        <select class="form-control form-control-sm" name="KalipReceteleri[@index].Birim">
                                            @if (item.Birim == "KG")
                                            {
                                                <option value="KG" selected>KG</option>
                                                <option value="ADET">ADET</option>
                                                <option value="LT">LT</option>
                                            }
                                            else if (item.Birim == "ADET")
                                            {
                                                <option value="KG">KG</option>
                                                <option value="ADET" selected>ADET</option>
                                                <option value="LT">LT</option>
                                            }
                                            else
                                            {
                                                <option value="KG">KG</option>
                                                <option value="ADET">ADET</option>
                                                <option value="LT" selected>LT</option>
                                            }
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">Henüz kalıp reçetesi tanımlanmamış.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- ================================================ -->
    <!-- 3. MAÇA REÇETESİ (YENİ) -->
    <!-- ================================================ -->
    <div class="card mb-4">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Maça Reçetesi</h5>
            <div>
                <button type="button" class="btn btn-dark btn-sm" onclick="addMacaRow()">
                    <i class="fas fa-plus"></i> Satır Ekle
                </button>
                <button type="button" class="btn btn-light btn-sm" onclick="macaOtomatikOlustur()">
                    <i class="fas fa-magic"></i> Oluştur
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="macaTable">
                    <thead>
                        <tr>
                            <th>Maça Adı</th>
                            <th>Maça Kodu</th>
                            <th>Kullanım Adedi</th>
                            <th>Maça Cinsi</th>
                            <th>Çevrim Süresi (dk)</th>
                            <th style="width:50px;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="macaTbody">
                        @if (Model.MacaReceteleri != null && Model.MacaReceteleri.Any())
                        {
                            int index = 0;
                            foreach (var item in Model.MacaReceteleri)
                            {
                                <tr>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" name="MacaReceteleri[@index].MacaAdi" value="@item.MacaAdi" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" name="MacaReceteleri[@index].MacaKodu" value="@item.MacaKodu" />
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" name="MacaReceteleri[@index].KullanimAdedi" value="@item.KullanimAdedi" />
                                    </td>
                                    <td>
                                        <select class="form-control form-control-sm" name="MacaReceteleri[@index].MacaCinsi">
                                            <option value="">Seçiniz</option>
                                            @if (item.MacaCinsi == "REÇİNELİ")
                                            {
                                                <option value="REÇİNELİ" selected>REÇİNELİ</option>
                                                <option value="COLD BOX">COLD BOX</option>
                                                <option value="HOT BOX">HOT BOX</option>
                                                <option value="BEZİR YAĞLI">BEZİR YAĞLI</option>
                                            }
                                            else if (item.MacaCinsi == "COLD BOX")
                                            {
                                                <option value="REÇİNELİ">REÇİNELİ</option>
                                                <option value="COLD BOX" selected>COLD BOX</option>
                                                <option value="HOT BOX">HOT BOX</option>
                                                <option value="BEZİR YAĞLI">BEZİR YAĞLI</option>
                                            }
                                            else if (item.MacaCinsi == "HOT BOX")
                                            {
                                                <option value="REÇİNELİ">REÇİNELİ</option>
                                                <option value="COLD BOX">COLD BOX</option>
                                                <option value="HOT BOX" selected>HOT BOX</option>
                                                <option value="BEZİR YAĞLI">BEZİR YAĞLI</option>
                                            }
                                            else if (item.MacaCinsi == "BEZİR YAĞLI")
                                            {
                                                <option value="REÇİNELİ">REÇİNELİ</option>
                                                <option value="COLD BOX">COLD BOX</option>
                                                <option value="HOT BOX">HOT BOX</option>
                                                <option value="BEZİR YAĞLI" selected>BEZİR YAĞLI</option>
                                            }
                                            else
                                            {
                                                <option value="REÇİNELİ">REÇİNELİ</option>
                                                <option value="COLD BOX">COLD BOX</option>
                                                <option value="HOT BOX">HOT BOX</option>
                                                <option value="BEZİR YAĞLI">BEZİR YAĞLI</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" name="MacaReceteleri[@index].MacaCevrimSuresi" value="@item.MacaCevrimSuresi" />
                                    </td>
                                    <td class="text-center">
                                        <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ================================================ -->
    <!-- 4. TORNA VE İŞLEME MERKEZİ REÇETESİ -->
    <!-- ================================================ -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Torna ve İşleme Merkezi Reçetesi</h5>
            <button type="button" class="btn btn-light btn-sm" onclick="addIslemeRow()">+ Satır Ekle</button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="islemeTable">
                    <thead>
                        <tr>
                            <th>Op. Sırası</th>
                            <th>Op. Kodu</th>
                            <th>Op. Adı</th>
                            <th>İş Merkezi</th>
                            <th>Takım Tüketimi</th>
                            <th>Stok Kodu</th>
                            <th>Stok Adı</th>
                            <th>Elektrik (kWh)</th>
                            <th style="width:50px;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- JavaScript ile satır eklenecek -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- ================================================ -->
    <!-- MAÇA REÇETESİ (OTOMATİK) -->
    <!-- ================================================ -->
    <div class="card mb-4">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Maça Reçetesi</h5>
            <button type="button" class="btn btn-dark btn-sm" onclick="macaOtomatikOlustur()">
                <i class="fas fa-magic"></i> Oluştur
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="macaReçeteTable">
                    <thead>
                        <tr>
                            <th>Stok Tipi</th>
                            <th>Stok Adı</th>
                            <th>Stok Kodu</th>
                            <th>Miktar</th>
                            <th>Birim</th>
                            <th style="width:50px;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="macaReçeteTbody">
                        @if (Model.MacaReceteleri != null && Model.MacaReceteleri.Any())
                        {
                            // Burada maça reçetesi verileri gösterilecek
                            // İleride doldurulacak
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ================================================ -->
    <!-- 5. KAYDET BUTONU -->
    <!-- ================================================ -->
    <div class="form-group mt-3">
        <input type="submit" value="Ürünü Kaydet" class="btn btn-primary btn-lg" />
        <a asp-action="Index" class="btn btn-secondary btn-lg">Listeye Dön</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            // Enter tuşunu engelle
            $('form').on('keydown', 'input, select, textarea', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    return false;
                }
            });

            // ==========================================
            // STOK TİPİNE GÖRE STOK ADLARINI FİLTRELE
            // ==========================================
            $(document).on('change', '.stok-tipi', function () {
                var row = $(this).closest('tr');
                var stokTipi = $(this).val();
                var stokAdiSelect = row.find('.stok-adi');
                var stokKoduInput = row.find('.stok-kodu');

                // Stok adı select'ini temizle
                stokAdiSelect.empty();
                stokAdiSelect.append('<option value="">Seçiniz</option>');

                if (stokTipi) {
                    // AJAX ile stokları getir
                    $.ajax({
                        url: '/Urun/GetStoklarByTip',
                        type: 'GET',
                        data: { stokTipi: stokTipi },
                        success: function (data) {
                            $.each(data, function (index, item) {
                                stokAdiSelect.append('<option value="' + item.stokAdi + '" data-stokkodu="' + item.stokKodu + '">' + item.stokAdi + '</option>');
                            });
                        },
                        error: function () {
                            alert('Stoklar yüklenirken bir hata oluştu.');
                        }
                    });
                }
            });

            // Stok adı seçildiğinde stok kodunu otomatik doldur
            $(document).on('change', '.stok-adi', function () {
                var row = $(this).closest('tr');
                var selectedOption = $(this).find('option:selected');
                var stokKodu = selectedOption.data('stokkodu');
                row.find('.stok-kodu').val(stokKodu || '');
            });

            // ==========================================
            // ALAŞIM NORMLARI (Dinamik Filtreleme)
            // ==========================================
            var alasimNormlari = {
                'PİK': ['GG20', 'GG30', 'GG40'],
                'SFERO': ['GGG40', 'GGG50', 'GGG60']
            };

            $('#Alasim').change(function () {
                var selectedAlasim = $(this).val();
                var $normSelect = $('#AlasimNormu');
                $normSelect.empty();
                if (selectedAlasim && alasimNormlari[selectedAlasim]) {
                    $normSelect.append('<option value="">Alaşım Normu Seçiniz</option>');
                    $.each(alasimNormlari[selectedAlasim], function (index, norm) {
                        $normSelect.append('<option value="' + norm + '">' + norm + '</option>');
                    });
                } else {
                    $normSelect.append('<option value="">Önce Alaşım Seçiniz</option>');
                }
            });
        });

        function addMacaRow() {
            var table = document.getElementById('macaTable').getElementsByTagName('tbody')[0];
            var row = table.insertRow();
            row.innerHTML = `
                        <td><input type="text" name="MacaReceteleri[0].MacaAdi" class="form-control form-control-sm" /></td>
                        <td><input type="text" name="MacaReceteleri[0].MacaKodu" class="form-control form-control-sm" /></td>
                        <td><input type="number" name="MacaReceteleri[0].MacaKullanimAdedi" class="form-control form-control-sm" /></td>
                        <td><select name="MacaReceteleri[0].MacaCinsi" class="form-control form-control-sm"><option value="">Seçiniz</option><option value="REÇİNELİ">REÇİNELİ</option><option value="COLD BOX">COLD BOX</option><option value="HOT BOX">HOT BOX</option><option value="BEZİR YAĞLI">BEZİR YAĞLI</option></select></td>
                        <td><input type="number" step="any" name="MacaReceteleri[0].KumTuketimi" class="form-control form-control-sm" /></td>
                        <td><input type="number" step="any" name="MacaReceteleri[0].RecineTuketimi" class="form-control form-control-sm" /></td>
                        <td><input type="number" step="any" name="MacaReceteleri[0].Co2Tuketimi" class="form-control form-control-sm" /></td>
                        <td><input type="number" step="any" name="MacaReceteleri[0].AminGazi" class="form-control form-control-sm" /></td>
                        <td><input type="number" step="any" name="MacaReceteleri[0].BezirYagiTuketimi" class="form-control form-control-sm" /></td>
                        <td><button type="button" class="btn btn-danger btn-sm btn-satir-sil">Sil</button></td>
                    `;
        }

        function addIslemeRow() {
            var table = document.getElementById('islemeTable').getElementsByTagName('tbody')[0];
            var row = table.insertRow();
            row.innerHTML = `
                        <td><input type="number" name="IslemeReceteleri[0].OperasyonSırası" class="form-control form-control-sm" /></td>
                        <td><input type="text" name="IslemeReceteleri[0].OperasyonKodu" class="form-control form-control-sm" /></td>
                        <td><input type="text" name="IslemeReceteleri[0].OperasyonAdi" class="form-control form-control-sm" /></td>
                        <td><input type="text" name="IslemeReceteleri[0].IsMerkezi" class="form-control form-control-sm" placeholder="Ergitme, Torna, vb." /></td>
                        <td><input type="number" step="any" name="IslemeReceteleri[0].TakimTuketimi" class="form-control form-control-sm" /></td>
                        <td><input type="text" name="IslemeReceteleri[0].StokKodu" class="form-control form-control-sm" /></td>
                        <td><input type="text" name="IslemeReceteleri[0].StokAdi" class="form-control form-control-sm" /></td>
                        <td><input type="number" step="any" name="IslemeReceteleri[0].BirimElektrikTuketimi" class="form-control form-control-sm" /></td>
                        <td><button type="button" class="btn btn-danger btn-sm btn-satir-sil">Sil</button></td>
                    `;
        }
        // ==========================================
        // OTOMATİK ERGİTME REÇETESİ OLUŞTUR
        // ==========================================
        function otomatikOlustur() {
            // Ürün bilgilerini al
            var alasimSinifi = document.getElementById('AlasimNormu')?.value || '';
            var urunAgirligi = parseFloat(document.getElementById('UrunAgirligi')?.value) || 0;
            var fireOrani = parseFloat(document.getElementById('FireOrani')?.value) || 0;

            // Kontroller
            if (!alasimSinifi) {
                alert('Lütfen önce Alaşım Normu seçiniz.');
                return;
            }

            if (urunAgirligi <= 0) {
                alert('Lütfen geçerli bir Ürün Ağırlığı giriniz.');
                return;
            }

            // AJAX ile alaşım oranlarını getir
            $.ajax({
                url: '/Urun/GetAlasimOranlari',
                type: 'GET',
                data: { alasimSinifi: alasimSinifi },
                success: function (data) {
                    if (data && data.length > 0) {
                        var tbody = document.getElementById('ergitmeTbody');
                        tbody.innerHTML = '';

                        var fireCarpani = 1 - (fireOrani / 100);

                        data.forEach(function (item, index) {
                            var miktar = (urunAgirligi * (item.oran / 100)) / fireCarpani;

                            var row = tbody.insertRow();
                            row.innerHTML = `
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="ErgitmeReceteleri[${index}].StokTipi" value="${item.stokTipi || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="ErgitmeReceteleri[${index}].StokAdi" value="${item.hammaddeAdi || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="ErgitmeReceteleri[${index}].StokKodu" value="${item.hammaddeKodu || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="number" step="any" name="ErgitmeReceteleri[${index}].Miktar" class="form-control form-control-sm" value="${miktar.toFixed(2)}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <select class="form-control form-control-sm" name="ErgitmeReceteleri[${index}].Birim">
                                        <option value="KG" selected>KG</option>
                                        <option value="ADET">ADET</option>
                                        <option value="LT">LT</option>
                                    </select>
                                </td>
                                <td class="text-center">
                                    <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                                </td>
                            `;
                        });
                    } else {
                        alert('Bu alaşım sınıfı için kayıtlı oran bulunamadı.');
                    }
                },
                error: function () {
                    alert('Alaşım oranları yüklenirken bir hata oluştu.');
                }
            });
        }
        // ==========================================
        // OTOMATİK KALIP REÇETESİ OLUŞTUR
        // ==========================================
        function kalipOtomatikOlustur() {
            var kalipCinsi = document.getElementById('KalipCinsi')?.value || '';
            var kalipAgirligi = parseFloat(document.getElementById('KalipAgirligi')?.value) || 0;
            var besleyiciStokKodu = document.getElementById('BesleyiciStokKodu')?.value || '';
            var besleyiciAdeti = parseInt(document.getElementById('BesleyiciAdeti')?.value) || 0;
            var parcaAdeti = parseInt(document.getElementById('UrunParcaAdeti')?.value) || 1; // Varsayılan 1

            // Kontroller
            if (!kalipCinsi) {
                alert('Lütfen önce Kalıp Cinsi seçiniz.');
                return;
            }

            if (kalipAgirligi <= 0) {
                alert('Lütfen geçerli bir Kalıp Ağırlığı giriniz.');
                return;
            }

            if (parcaAdeti <= 0) {
                alert('Lütfen geçerli bir Parça Adedi/Kalıp giriniz.');
                return;
            }

            // AJAX ile verileri getir
            $.ajax({
                url: '/Urun/GetKalipReceteData',
                type: 'GET',
                data: {
                    kalipCinsi: kalipCinsi,
                    besleyiciStokKodu: besleyiciStokKodu,
                    besleyiciAdeti: besleyiciAdeti,
                    parcaAdeti: parcaAdeti
                },
                success: function (data) {
                    if (data && data.length > 0) {
                        var tbody = document.getElementById('kalipTbody');
                        tbody.innerHTML = '';

                        data.forEach(function (item, index) {
                            var miktar = 0;
                            if (item.kaynak === 'Besleyici') {
                                miktar = item.miktar; // BesleyiciAdeti / ParcaAdeti
                            } else {
                                // KalipAgirligi * (Oran / 100) / ParcaAdeti
                                miktar = (kalipAgirligi * (item.miktar / 100)) / parcaAdeti;
                            }

                            var row = tbody.insertRow();
                            row.innerHTML = `
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="KalipReceteleri[${index}].StokTipi" value="${item.stokTipi || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="KalipReceteleri[${index}].StokAdi" value="${item.stokAdi || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="KalipReceteleri[${index}].StokKodu" value="${item.stokKodu || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="number" step="any" name="KalipReceteleri[${index}].Miktar" class="form-control form-control-sm" value="${miktar.toFixed(2)}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <select class="form-control form-control-sm" name="KalipReceteleri[${index}].Birim">
                                        <option value="${item.birim || 'KG'}" selected>${item.birim || 'KG'}</option>
                                        <option value="KG">KG</option>
                                        <option value="ADET">ADET</option>
                                        <option value="LT">LT</option>
                                    </select>
                                </td>
                                <td class="text-center">
                                    <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                                </td>
                            `;
                        });
                    } else {
                        alert('Bu kalıp cinsi için kayıtlı sarf oranı bulunamadı.');
                    }
                },
                error: function () {
                    alert('Veriler yüklenirken bir hata oluştu.');
                }
            });
        }
        // ==========================================
        // OTOMATİK MAÇA REÇETESİ OLUŞTUR
        // ==========================================
        function macaOtomatikOlustur() {
            // Maça Cinsi seçimini al (ilk maça cinsi)
            var macaCinsi = document.querySelector('#macaVeriTbody select[name$=".MacaCinsi"]')?.value || '';

            if (!macaCinsi) {
                alert('Lütfen önce Maça Bilgileri kısmından bir maça cinsi seçiniz.');
                return;
            }

            // Maça miktarı (Kullanım Adedi / Parça Adeti)
            var kullanimAdedi = parseFloat(document.querySelector('#macaVeriTbody input[name$=".KullanimAdedi"]')?.value) || 1;
            var parcaAdeti = parseInt(document.getElementById('UrunParcaAdeti')?.value) || 1;

            $.ajax({
                url: '/Urun/GetMacaOranlari',
                type: 'GET',
                data: { macaCinsi: macaCinsi },
                success: function (data) {
                    if (data && data.length > 0) {
                        var tbody = document.getElementById('macaReçeteTbody');
                        tbody.innerHTML = '';

                        var birimMiktar = kullanimAdedi / parcaAdeti;

                        data.forEach(function (item, index) {
                            var miktar = birimMiktar * (item.miktar / 100);

                            var row = tbody.insertRow();
                            row.innerHTML = `
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="MacaReceteleri[${index}].StokTipi" value="${item.stokTipi || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="MacaReceteleri[${index}].StokAdi" value="${item.sarfAdi || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" name="MacaReceteleri[${index}].StokKodu" value="${item.sarfKodu || ''}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <input type="number" step="any" name="MacaReceteleri[${index}].Miktar" class="form-control form-control-sm" value="${miktar.toFixed(2)}" readonly style="background-color: #e9ecef;" />
                                </td>
                                <td>
                                    <select class="form-control form-control-sm" name="MacaReceteleri[${index}].Birim">
                                        <option value="${item.birim || 'KG'}" selected>${item.birim || 'KG'}</option>
                                        <option value="KG">KG</option>
                                        <option value="ADET">ADET</option>
                                        <option value="LT">LT</option>
                                    </select>
                                </td>
                                <td class="text-center">
                                    <i class="fas fa-trash text-danger satir-sil" onclick="satirSil(this)"></i>
                                </td>
                            `;
                        });
                    } else {
                        alert('Bu maça cinsi için kayıtlı sarf oranı bulunamadı.');
                    }
                },
                error: function () {
                    alert('Maça oranları yüklenirken bir hata oluştu.');
                }
            });
        }

        function satirSil(element) {
            var row = element.closest('tr');
            row.remove();
        }

        function satirSil(element) {
            var row = element.closest('tr');
            row.remove();
        }
    </script>
}